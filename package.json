{
  "name": "feedy",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-ready product feedback infrastructure.",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "build:api": "npm run build -w @feedy/example-api-adapter",
    "dev:ui": "npm run dev -w @feedy/example-ui-reference",
    "export:public": "node scripts/export-public.mjs",
    "test": "npm run test -w @feedy/contracts",
    "typecheck": "tsc -b --pretty false",
    "smoke": "npm run typecheck && npm run test"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4"
  }
}
